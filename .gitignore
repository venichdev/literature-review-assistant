# Literature Review Template - .gitignore

# ============================================================
# Personal Configuration
# ============================================================
# Don't commit your personal config file (use config.example.yaml as template)
config.yaml
*.local.yaml

# Web App Environment
.env
.flaskenv
instance/
*.db
*.sqlite

# ============================================================
# Output Directories
# ============================================================
# Generated outputs (keep structure, ignore content)
outputs/
!outputs/.gitkeep

# Alternative output directories
results/
review_output/
literature_review_*/

# ============================================================
# Papers and PDFs
# ============================================================
# Don't commit copyrighted papers
*.pdf
papers/
pdfs/
fulltext/

# ============================================================
# Bibliography and Reference Managers
# ============================================================
# Reference manager files
*.bib.bak
*.bib.sav
*-blx.bib

# Zotero
zotero/
*.sqlite

# Mendeley
mendeley/

# EndNote
*.enl
*.enlx

# ============================================================
# Temporary Files
# ============================================================
# System files
.DS_Store
Thumbs.db
desktop.ini

# Temporary text editor files
*~
*.swp
*.swo
*.tmp
.*.sw?

# ============================================================
# Python (if using Python scripts)
# ============================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/
.venv
*.egg-info/
dist/
build/

# ============================================================
# R (if using R for analysis)
# ============================================================
.Rhistory
.RData
.Rproj.user/

# ============================================================
# MATLAB
# ============================================================
*.asv
*.m~

# ============================================================
# Jupyter Notebooks
# ============================================================
.ipynb_checkpoints/
*.ipynb_checkpoints

# ============================================================
# Node.js (if using JS tools)
# ============================================================
node_modules/
npm-debug.log
yarn-error.log

# ============================================================
# LaTeX (if generating LaTeX documents)
# ============================================================
*.aux
*.log
*.out
*.toc
*.synctex.gz
*.fdb_latexmk
*.fls
*.bbl
*.blg

# ============================================================
# Microsoft Office
# ============================================================
~$*.doc*
~$*.xls*
~$*.ppt*
*.tmp

# ============================================================
# Backup Files
# ============================================================
*.backup
*.bak
*_backup/
backups/

# ============================================================
# Cache and Logs
# ============================================================
cache/
.cache/
logs/
*.log

# ============================================================
# IDE and Editor Specific
# ============================================================
# VS Code
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# JetBrains IDEs
.idea/
*.iml
*.iws

# Sublime Text
*.sublime-project
*.sublime-workspace

# ============================================================
# Personal Notes (Optional)
# ============================================================
# Uncomment if you don't want to share personal notes
# notes/
# personal_notes.md
# scratch.md

# ============================================================
# Data Files (Large)
# ============================================================
# Uncomment if you have large datasets
# data/
# *.csv
# *.xlsx
# *.json

# ============================================================
# Keep Empty Directories
# ============================================================
# Git doesn't track empty directories, so we use .gitkeep
!.gitkeep
